# ── Azure OpenAI (Required) ──────────────────────────────────────────────────
# Your Azure OpenAI API key (found under Keys and Endpoint in Azure Portal)
AZURE_KEY=your_azure_openai_api_key_here

# Your Azure OpenAI endpoint URL
# Format: https://<resource-name>.openai.azure.com/
AZURE_ENDPOINT=https://your-resource-name.openai.azure.com/

# The name of your Azure OpenAI deployment (e.g. gpt-4o)
AZURE_NAME=gpt-4o

# Azure OpenAI API version string
AZURE_VERSION=2024-05-01-preview

# Some SDK paths require this separately — set it to the same value as AZURE_KEY
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# ── OpenAI Direct (Optional) ─────────────────────────────────────────────────
# Only needed if using direct OpenAI (non-Azure) as a judge fallback
OPENAI_API_KEY=sk-proj-your_openai_key_here

# ── Opik (Optional) ──────────────────────────────────────────────────────────
# Only needed if sending metrics to Opik Cloud.
# Local Opik-style scoring runs entirely through Azure OpenAI and does not need this.
OPIK_API_KEY=your_opik_api_key_here
